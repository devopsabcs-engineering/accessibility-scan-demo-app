{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.7.0/schema.json",
  "name": "stacked_bar_site_impact",
  "position": {
    "x": 20,
    "y": 80,
    "z": 1000,
    "height": 420,
    "width": 820,
    "tabOrder": 1000
  },
  "visual": {
    "visualType": "barChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "Dim_Site"
                    }
                  },
                  "Property": "SiteName"
                }
              },
              "queryRef": "Dim_Site.SiteName",
              "nativeQueryRef": "Site",
              "active": true
            }
          ]
        },
        "Series": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "Dim_Impact"
                    }
                  },
                  "Property": "Impact"
                }
              },
              "queryRef": "Dim_Impact.Impact",
              "nativeQueryRef": "Impact"
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "Fact_A11yViolations"
                    }
                  },
                  "Property": "Total Violations"
                }
              },
              "queryRef": "Fact_A11yViolations.Total Violations",
              "nativeQueryRef": "Count of Violations"
            }
          ]
        }
      },
      "sortDefinition": {
        "sort": [
          {
            "field": {
              "Measure": {
                "Expression": {
                  "SourceRef": {
                    "Entity": "Fact_A11yViolations"
                  }
                },
                "Property": "Total Violations"
              }
            },
            "direction": "Descending"
          }
        ],
        "isDefaultSort": true
      }
    },
    "objects": {
      "legend": [
        {
          "properties": {
            "show": {
              "expr": {
                "Literal": {
                  "Value": "true"
                }
              }
            },
            "position": {
              "expr": {
                "Literal": {
                  "Value": "'Top'"
                }
              }
            }
          }
        }
      ]
    },
    "visualContainerObjects": {
      "title": [
        {
          "properties": {
            "text": {
              "expr": {
                "Literal": {
                  "Value": "'Accessibility Issues by Site'"
                }
              }
            },
            "show": {
              "expr": {
                "Literal": {
                  "Value": "true"
                }
              }
            }
          }
        }
      ]
    },
    "drillFilterOtherVisuals": true
  }
}