	partition Fact_A11yViolations = m
		mode: import
		source =
				let
				StorageUrl = "https://" & StorageAccountName & ".blob.core.windows.net/" & ContainerName,
					Source = AzureStorage.Blobs(StorageUrl),
					FilteredRows = Table.SelectRows(Source, each Text.EndsWith([Name], ".json")),
					ParsedContent = Table.AddColumn(FilteredRows, "ParsedJson", each Json.Document([Content])),
					ExpandedRows = Table.ExpandListColumn(ParsedContent, "ParsedJson"),
					ExpandedCols = Table.ExpandRecordColumn(ExpandedRows, "ParsedJson",
						{"ViolationId", "RuleId", "RuleName", "Description", "HelpUrl",
						 "Impact", "WcagCriterionKey", "PrincipleKey", "StateKey",
						 "SiteKey", "EngineKey", "PageUrl", "TargetElement",
						 "ElementCount", "ScanDate", "FixedDate", "ScanRunId"})
				in
					ExpandedCols

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

