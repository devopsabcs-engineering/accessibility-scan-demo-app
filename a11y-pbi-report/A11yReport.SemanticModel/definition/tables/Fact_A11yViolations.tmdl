table Fact_A11yViolations
	lineageTag: a1b2c3d4-e5f6-7890-abcd-ef1234567890

	measure 'Total Violations' = COUNTROWS(Fact_A11yViolations)
		formatString: #,0
		lineageTag: 20000001-0001-0001-0001-000000000001

	measure 'Active Violations' = CALCULATE(COUNTROWS(Fact_A11yViolations), Dim_State[State] = "active")
		formatString: #,0
		lineageTag: 20000001-0001-0001-0001-000000000002

	measure 'Fixed Violations' = CALCULATE(COUNTROWS(Fact_A11yViolations), Dim_State[State] = "fixed")
		formatString: #,0
		lineageTag: 20000001-0001-0001-0001-000000000003

	measure 'Fix Rate %' = IF([Total Violations] = 0, 0, DIVIDE([Fixed Violations], [Total Violations], 0)) + 0
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: 20000001-0001-0001-0001-000000000004

	measure 'Sites Scanned' = DISTINCTCOUNT(Fact_A11yViolations[SiteKey])
		formatString: #,0
		lineageTag: 20000001-0001-0001-0001-000000000005

	measure 'Pages Scanned' = DISTINCTCOUNT(Fact_A11yViolations[PageUrl])
		formatString: #,0
		lineageTag: 20000001-0001-0001-0001-000000000006

	measure 'Unique Rules Violated' = DISTINCTCOUNT(Fact_A11yViolations[RuleId])
		formatString: #,0
		lineageTag: 20000001-0001-0001-0001-000000000007

	measure 'Total Elements Affected' = SUM(Fact_A11yViolations[ElementCount])
		formatString: #,0
		lineageTag: 20000001-0001-0001-0001-000000000008

	measure 'Critical Violations' = CALCULATE([Total Violations], Dim_Impact[Impact] = "critical")
		formatString: #,0
		lineageTag: 20000001-0001-0001-0001-000000000009

	measure 'Serious Violations' = CALCULATE([Total Violations], Dim_Impact[Impact] = "serious")
		formatString: #,0
		lineageTag: 20000001-0001-0001-0001-00000000000a

	measure 'Critical + Serious' = [Critical Violations] + [Serious Violations]
		formatString: #,0
		lineageTag: 20000001-0001-0001-0001-00000000000b

	measure 'Perceivable Violations' = CALCULATE([Total Violations], Dim_Principle[PrincipleName] = "Perceivable")
		formatString: #,0
		lineageTag: 20000001-0001-0001-0001-00000000000c

	measure 'Operable Violations' = CALCULATE([Total Violations], Dim_Principle[PrincipleName] = "Operable")
		formatString: #,0
		lineageTag: 20000001-0001-0001-0001-00000000000d

	measure 'Understandable Violations' = CALCULATE([Total Violations], Dim_Principle[PrincipleName] = "Understandable")
		formatString: #,0
		lineageTag: 20000001-0001-0001-0001-00000000000e

	measure 'Robust Violations' = CALCULATE([Total Violations], Dim_Principle[PrincipleName] = "Robust")
		formatString: #,0
		lineageTag: 20000001-0001-0001-0001-00000000000f

	measure 'Weighted Compliance Score' = 100 - SUMX(Fact_A11yViolations, SWITCH(RELATED(Dim_Impact[Impact]), "critical", 10, "serious", 7, "moderate", 3, "minor", 1, 0))
		formatString: 0.0
		lineageTag: 20000001-0001-0001-0001-000000000010

	measure 'Mean Time to Fix' =
			AVERAGEX(
				FILTER(Fact_A11yViolations, NOT(ISBLANK(Fact_A11yViolations[FixedDate]))),
				DATEDIFF(Fact_A11yViolations[ScanDate], Fact_A11yViolations[FixedDate], DAY)
			)
		formatString: 0.0
		lineageTag: 20000001-0001-0001-0001-000000000011

